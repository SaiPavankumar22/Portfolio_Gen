# ============================================================
#  PortfolioAI — .gitignore
# ============================================================

# ── Node / Frontend ─────────────────────────────────────────
node_modules/
frontend/node_modules/
dist/
dist-ssr/
*.local

# Build output
frontend/dist/
frontend/dist-ssr/

# ── Python / Backend ────────────────────────────────────────
__pycache__/
backend/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
backend/venv/
.venv/
env/
ENV/

# Python packaging / eggs
*.egg-info/
.eggs/
dist/
build/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy
.mypy_cache/

# ── Environment Variables ────────────────────────────────────
# Never commit secrets — each developer keeps their own .env
.env
.env.*
!.env.example

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / OS ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
